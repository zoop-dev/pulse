+<?xml version="1.0" encoding="utf-8"?>
+<!-- Pulse: daily goals, split into their own screen -->
+<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
+    xmlns:app="http://schemas.android.com/apk/res-auto">
