+    <color name="pulse_text">#ECEBE6</color>
+    <color name="pulse_text_dim">#8A8A93</color>
+    <!-- Pulse accent choices (dark-mode, vibrant) -->
+    <color name="accent_blue">#2BB8FF</color>
+    <color name="accent_violet">#8C6BFF</color>
+    <color name="accent_coral">#FF6B6B</color>
