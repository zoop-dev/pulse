<?xml version="1.0" encoding="utf-8"?>
<!-- Pulse: Google-Health "Today" home, dark + neon-blue -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pulse_bg"
    tools:context=".activities.DashboardFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: device chip + greeting + big title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="12dp">

            <!-- Device + battery chip (tap = open Devices) -->
            <LinearLayout
                android:id="@+id/pulse_device_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/pulse_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/pulse_device_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/pulse_status_dot" />

                <TextView
                    android:id="@+id/pulse_device_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pulse_no_device"
                    android:textColor="@color/pulse_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pulse_device_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/pulse_neon_cyan"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/dashboard_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pulse_greeting"
                android:textColor="@color/pulse_text_dim"
                android:textSize="15sp"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/dashboard_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activity_summary_today"
                android:textColor="@color/pulse_text"
                android:textStyle="bold"
                android:fontFamily="@font/unbounded"
                android:textSize="30sp"
                android:letterSpacing="-0.02" />
        </LinearLayout>

        <!-- Today only: swipeable carousel (ring page + tile pages) + dot indicator.
             Wrapped so its horizontal swipes don't fight the outer tab pager. -->
        <nodomain.freeyourgadget.gadgetbridge.activities.views.NestedScrollableHost
            android:id="@+id/pulse_carousel_host"
            android:layout_width="match_parent"
            android:layout_height="188dp"
            android:visibility="gone">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/pulse_today_carousel"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </nodomain.freeyourgadget.gadgetbridge.activities.views.NestedScrollableHost>

        <LinearLayout
            android:id="@+id/pulse_carousel_dots"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <!-- Today only: expanded (no-swipe) hero — ring + every tile stacked, built in code -->
        <LinearLayout
            android:id="@+id/pulse_today_expanded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:visibility="gone" />

        <!-- Hero row: big steps ring + stacked stat cards -->
        <LinearLayout
            android:id="@+id/pulse_hero_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:baselineAligned="false">

            <FrameLayout
                android:layout_width="158dp"
                android:layout_height="158dp"
                android:layout_gravity="center_vertical">

                <nodomain.freeyourgadget.gadgetbridge.activities.views.PulseRingView
                    android:id="@+id/pulse_ring"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/pulse_ring_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/steps"
                        android:textColor="@color/pulse_text_dim"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/pulse_ring_value"
                        android:layout_width="116dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:gravity="center"
                        android:maxLines="1"
                        android:textColor="@color/pulse_text"
                        android:textStyle="bold"
                        android:fontFamily="@font/unbounded"
                        android:includeFontPadding="false"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="13sp"
                        app:autoSizeMaxTextSize="38sp" />

                    <TextView
                        android:id="@+id/pulse_ring_goal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pulse_of_goal"
                        android:textColor="@color/pulse_ring_steps"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/pulse_stat_column"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="14dp">

            </LinearLayout>
        </LinearLayout>

        <!-- Pulse: inline sleep detail (Sleep tab only; built in code) -->
        <LinearLayout
            android:id="@+id/pulse_sleep_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <!-- Action pills -->
        <LinearLayout
            android:id="@+id/pulse_pills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="16dp"
            android:paddingBottom="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pulse_btn_log"
                style="@style/Widget.Material3.Button.TonalButton.Icon"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="0"
                android:textColor="@color/pulse_text"
                android:textSize="17sp"
                android:fontFamily="@font/clashdisplay_bold"
                app:backgroundTint="@color/pulse_card"
                app:icon="@drawable/ic_ms_calories"
                app:iconGravity="textStart"
                app:iconSize="22dp"
                app:iconTint="@color/pulse_ring_cal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pulse_btn_start"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/pulse_start"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:fontFamily="@font/clashdisplay_bold"
                app:backgroundTint="?attr/pulseAccent"
                app:icon="@drawable/ic_ms_sync"
                app:iconGravity="textStart"
                app:iconSize="22dp"
                app:iconTint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pulse_btn_edit"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="10dp"
                app:backgroundTint="@color/pulse_card"
                app:icon="@drawable/ic_ms_edit"
                app:iconSize="24dp"
                app:iconTint="@color/pulse_text_dim" />
        </LinearLayout>

        <!-- Today only: stacked extra cards (This week, Recent workouts), built in code -->
        <LinearLayout
            android:id="@+id/pulse_today_extra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="24dp"
            android:visibility="gone" />

        <!-- Content sheet: detail cards + day nav (hidden on Today) -->
        <LinearLayout
            android:id="@+id/pulse_content_sheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="14dp"
            android:background="@drawable/pulse_content_sheet"
            android:paddingTop="14dp"
            android:minHeight="220dp">

            <!-- Day navigation strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="4dp">

                <Button
                    android:id="@+id/arrow_left"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:text="‹"
                    android:textColor="@color/pulse_text_dim"
                    android:textStyle="bold"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/pulse_details_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/pulse_details"
                    android:textColor="@color/pulse_text"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/arrow_right"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:text="›"
                    android:textColor="@color/pulse_text_dim"
                    android:textStyle="bold"
                    android:textSize="22sp" />
            </LinearLayout>

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/dashboard_gridlayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="6dp"
                android:paddingBottom="24dp"
                app:columnCount="2" />
        </LinearLayout>
    </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading overlay: shown until stats are warmed, so nothing pops in -->
    <LinearLayout
        android:id="@+id/pulse_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/pulse_bg"
        android:gravity="center"
        android:orientation="vertical">

        <com.google.android.material.loadingindicator.LoadingIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorColor="?attr/pulseAccent"
            app:indicatorSize="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/pulse_loading"
            android:textColor="@color/pulse_text_dim"
            android:fontFamily="@font/satoshi"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
