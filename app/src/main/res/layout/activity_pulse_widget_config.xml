<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pulse_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Live preview -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pulse_widget_preview"
            android:textAllCaps="true"
            android:textColor="?attr/pulseAccent"
            android:textSize="12sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <include
                android:id="@+id/widget_preview"
                layout="@layout/widget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </FrameLayout>

        <!-- Device -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pref_header_device"
            android:textAllCaps="true"
            android:textColor="?attr/pulseAccent"
            android:textSize="12sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:id="@+id/widget_device_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/pulse_widget_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/pulse_widget_device_hint"
                android:textColor="@color/pulse_text_dim"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/widget_device_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/pulse_text"
                android:textStyle="bold"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Stats -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pulse_widget_pick_stats"
            android:textAllCaps="true"
            android:textColor="?attr/pulseAccent"
            android:textSize="12sp"
            android:letterSpacing="0.08"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:text="@string/pulse_widget_slot_1"
                android:textColor="@color/pulse_text_dim"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/widget_slot0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:text="@string/pulse_widget_slot_2"
                android:textColor="@color/pulse_text_dim"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/widget_slot1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:text="@string/pulse_widget_slot_3"
                android:textColor="@color/pulse_text_dim"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/widget_slot2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <Button
            android:id="@+id/widget_save_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/pulse_widget_bg"
            android:backgroundTint="?attr/pulseAccent"
            android:text="@string/pulse_widget_save"
            android:textColor="@color/pulse_bg"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
