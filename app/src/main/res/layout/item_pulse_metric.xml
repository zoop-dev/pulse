<?xml version="1.0" encoding="utf-8"?>
<!-- Pulse: a draggable metric row in the dashboard editor -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/pulse_card"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    android:paddingHorizontal="14dp"
    android:paddingVertical="14dp">

    <ImageView
        android:id="@+id/pulse_metric_drag"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_baseline_drag_handle_24"
        app:tint="@color/pulse_text_dim"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:id="@+id/pulse_metric_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:textColor="@color/pulse_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/pulse_metric_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</LinearLayout>
