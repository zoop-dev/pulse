<?xml version="1.0" encoding="utf-8"?>
<!-- Pulse: off-screen layout rendered to a bitmap for sharing an unlocked achievement. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/pulse_bg"
    android:gravity="center_horizontal"
    android:padding="48dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_notification"
            app:tint="?attr/pulseAccent" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="@string/pulse_wordmark"
            android:fontFamily="@font/unbounded"
            android:textColor="@color/pulse_text"
            android:textSize="20sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pulse_badge_unlocked"
            android:textAllCaps="true"
            android:letterSpacing="0.06"
            android:textColor="?attr/pulseAccent"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/badge_share_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="52dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/badge_share_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/unbounded"
        android:textColor="@color/pulse_text"
        android:textSize="34sp"
        android:gravity="center"
        android:layout_marginBottom="52dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pulse_share_brand"
        android:textColor="?attr/pulseAccent"
        android:textSize="15sp" />
</LinearLayout>
